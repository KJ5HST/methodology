#!/usr/bin/env python3
"""Sync methodology starter-kit files into a project.

Contract: methodology v2.2 plan §4D.
"""
import argparse
import base64
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

REPO = "KJ5HST/methodology"
SYNC_FILES = ("SESSION_RUNNER.md", "SAFEGUARDS.md", "methodology_dashboard.py")
IGNORE_ENTRIES = tuple(f"/{name}" for name in SYNC_FILES)


def script_methodology_root() -> Path:
    # This script lives at <methodology>/bin/sync.
    return Path(__file__).resolve().parent.parent


def detect_mode(project: Path) -> str:
    gitignore = project / ".gitignore"
    if not gitignore.exists():
        return "commit"
    existing = set(line.strip() for line in gitignore.read_text().splitlines())
    if any(entry in existing for entry in IGNORE_ENTRIES):
        return "ignore"
    return "commit"


def detect_source(methodology_root: Path) -> str:
    if (methodology_root / "starter-kit").is_dir():
        return "local"
    return "github"


def read_local(methodology_root: Path, name: str) -> bytes:
    return (methodology_root / "starter-kit" / name).read_bytes()


def read_github(name: str) -> bytes:
    try:
        result = subprocess.run(
            ["gh", "api", f"repos/{REPO}/contents/starter-kit/{name}"],
            capture_output=True, text=True, check=True,
        )
    except FileNotFoundError:
        sys.exit("error: gh CLI not found; install GitHub CLI or use --source=local")
    except subprocess.CalledProcessError as e:
        sys.exit(f"error: gh api failed for {name}: {e.stderr.strip() or e.stdout.strip()}\n"
                 f"hint: run `gh auth login` or use --source=local")
    payload = json.loads(result.stdout)
    return base64.b64decode(payload["content"])


def methodology_version(methodology_root: Path, source: str) -> str:
    if source == "local":
        try:
            out = subprocess.run(
                ["git", "-C", str(methodology_root), "describe", "--tags", "--always"],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
            return out or "local"
        except (FileNotFoundError, subprocess.CalledProcessError):
            return "local"
    # github
    try:
        out = subprocess.run(
            ["gh", "api", f"repos/{REPO}/commits/main", "--jq", ".sha"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        return f"github:{out[:7]}" if out else "github:main"
    except (FileNotFoundError, subprocess.CalledProcessError):
        return "github:main"


def ensure_gitignore_entries(project: Path, dry_run: bool) -> list:
    gitignore = project / ".gitignore"
    current = gitignore.read_text().splitlines() if gitignore.exists() else []
    existing = set(line.strip() for line in current)
    to_add = [e for e in IGNORE_ENTRIES if e not in existing]
    if not to_add:
        return []
    if dry_run:
        return to_add
    with gitignore.open("a") as f:
        if current and current[-1].strip() != "":
            f.write("\n")
        f.write("# Methodology files (synced from ../methodology/; run ../methodology/bin/sync .)\n")
        for entry in to_add:
            f.write(entry + "\n")
    return to_add


def currently_tracked(project: Path) -> list:
    try:
        out = subprocess.run(
            ["git", "-C", str(project), "ls-files", "--error-unmatch", "--", *SYNC_FILES],
            capture_output=True, text=True, check=False,
        )
    except FileNotFoundError:
        return []
    return [line for line in out.stdout.splitlines() if line]


def sync_file(project: Path, name: str, content: bytes, dry_run: bool) -> str:
    target = project / name
    if target.exists() and target.read_bytes() == content:
        return "unchanged"
    action = "would write" if dry_run else ("updated" if target.exists() else "created")
    if not dry_run:
        target.write_bytes(content)
        if name.endswith(".py"):
            mode = target.stat().st_mode
            target.chmod(mode | 0o111)
    return action


def main() -> int:
    p = argparse.ArgumentParser(description="Sync methodology starter-kit files into a project.")
    p.add_argument("project_path", help="Target project directory")
    p.add_argument("--mode", choices=("commit", "ignore"), help="commit (default) or ignore")
    p.add_argument("--source", choices=("local", "github"), help="local (default if sibling methodology/ exists) or github")
    p.add_argument("--dry-run", action="store_true", help="Print intent without writing")
    args = p.parse_args()

    project = Path(args.project_path).resolve()
    if not project.is_dir():
        sys.exit(f"error: {project} is not a directory")

    methodology_root = script_methodology_root()
    source = args.source or detect_source(methodology_root)
    if source == "local" and not (methodology_root / "starter-kit").is_dir():
        sys.exit(f"error: --source=local but no starter-kit/ at {methodology_root}")

    mode = args.mode or detect_mode(project)
    version = methodology_version(methodology_root, source)

    print(f"sync: {project}")
    print(f"  source:  {source}" + (f" ({methodology_root})" if source == "local" else ""))
    print(f"  mode:    {mode}")
    print(f"  version: {version}")
    if args.dry_run:
        print("  (dry-run: no changes will be written)")

    file_results = []
    for name in SYNC_FILES:
        if source == "local":
            content = read_local(methodology_root, name)
        else:
            content = read_github(name)
        result = sync_file(project, name, content, args.dry_run)
        file_results.append((name, result))

    print("  files:")
    for name, result in file_results:
        print(f"    {name}: {result}")

    if mode == "ignore":
        added = ensure_gitignore_entries(project, args.dry_run)
        if added:
            verb = "would add" if args.dry_run else "added"
            print(f"  .gitignore: {verb} {', '.join(added)}")
        else:
            print("  .gitignore: entries already present")

        if (project / ".git").exists():
            tracked = currently_tracked(project)
            if tracked:
                print("")
                print("  WARNING: the following files are currently tracked by git:")
                for f in tracked:
                    print(f"    {f}")
                print("  Run this to stop tracking them (keeps local copies):")
                print(f"    git -C {project} rm --cached {' '.join(tracked)}")
                print("  Then commit the removal. This script does not run it for you.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
